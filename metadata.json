{
  "name": "sicura-simp_windows",
  "version": "2.0.0",
  "author": "Sicura, Inc.",
  "summary": "Apply Sicura compliance policies to Windows systems",
  "license": "AGPL-3.0-or-later",
  "source": "https://github.com/sicuraus/sicura-simp_windows.git",
  "project_page": "https://github.com/sicuraus/sicura-simp_windows",
  "issues_url": "https://github.com/sicuraus/sicura-simp_windows/issues",
  "dependencies": [
    {
      "name": "puppetlabs-acl",
      "version_requirement": ">= 4.1.0 < 6.0.0"
    },
    {
      "name": "fervid-auditpol",
      "version_requirement": ">= 1.0.0 < 2.0.0"
    },
    {
      "name": "simp-compliance_markup",
      "version_requirement": ">= 3.2.0 < 4.0.0"
    },
    {
      "name": "ayohrling-local_security_policy",
      "version_requirement": ">= 1.1.0 < 2.0.0"
    },
    {
      "name": "puppetlabs-powershell",
      "version_requirement": ">= 5.1.0 < 7.0.0"
    },
    {
      "name": "puppetlabs-registry",
      "version_requirement": ">= 4.1.0 < 6.0.0"
    },
    {
      "name": "ipcrm-registry_acl",
      "version_requirement": ">= 0.2.0 < 1.0.0"
    },
    {
      "name": "simp-simplib",
      "version_requirement": ">= 4.10.1 < 5.0.0"
    },
    {
      "name": "puppetlabs-stdlib",
      "version_requirement": ">= 8.2.0 < 10.0.0"
    },
    {
      "name": "puppet-windowsfeature",
      "version_requirement": ">= 4.0.0 < 6.0.0"
    },
    {
      "name": "puppet-windows_firewall",
      "version_requirement": ">= 4.1.0 < 7.0.0"
    },
    {
      "name": "puppetlabs-dism",
      "version_requirement": ">= 1.3.1 < 2.0.0"
    }
  ],
  "operatingsystem_support": [
    {
      "operatingsystem": "windows",
      "operatingsystemrelease": [
        "2016",
        "2019",
        "2022",
        "2025",
        "11"
      ]
    }
  ],
  "requirements": [
    {
      "name": "puppet",
      "version_requirement": ">= 7.0.0 < 9.0.0"
    },
    {
      "name": "openvox",
      "version_requirement": ">= 7.0.0 < 9.0.0"
    }
  ]
}
